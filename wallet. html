<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="UTF-8">
    <title>VaultWallet - نمونه سه‌بعدی</title>
    <style>
        body { margin: 0; overflow: hidden; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        #info {
            position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            pointer-events: none;
            z-index: 100;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div id="info">
        <strong>VaultWallet</strong> | کلیک و بکشید برای چرخاندن | اسکرول برای زوم
    </div>
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.128.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.128.0/examples/jsm/"
            }
        }
    </script>
    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
        import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

        // صحنه
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x111122);
        scene.fog = new THREE.FogExp2(0x111122, 0.008);

        // دوربین
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(5, 3, 5);
        camera.lookAt(0, 0, 0);

        // رندرر
        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.shadowMap.enabled = true;
        renderer.setPixelRatio(window.devicePixelRatio);
        document.body.appendChild(renderer.domElement);

        // رندرر متن (برای برچسب‌ها)
        const labelRenderer = new CSS2DRenderer();
        labelRenderer.setSize(window.innerWidth, window.innerHeight);
        labelRenderer.domElement.style.position = 'absolute';
        labelRenderer.domElement.style.top = '0px';
        labelRenderer.domElement.style.left = '0px';
        labelRenderer.domElement.style.pointerEvents = 'none';
        document.body.appendChild(labelRenderer.domElement);

        // کنترل
        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.autoRotate = true;
        controls.autoRotateSpeed = 1.0;
        controls.enableZoom = true;
        controls.enablePan = true;

        // نورپردازی
        // نور محیط
        const ambientLight = new THREE.AmbientLight(0x404060);
        scene.add(ambientLight);
        // نور اصلی جهت‌دار
        const dirLight = new THREE.DirectionalLight(0xffffff, 1);
        dirLight.position.set(2, 5, 3);
        dirLight.castShadow = true;
        dirLight.receiveShadow = false;
        scene.add(dirLight);
        // نور پرکننده از پشت
        const backLight = new THREE.PointLight(0x4466cc, 0.3);
        backLight.position.set(-1, 1, -2);
        scene.add(backLight);
        // نور گرم از پایین
        const fillLight = new THREE.PointLight(0xcc8844, 0.2);
        fillLight.position.set(0, -1, 1);
        scene.add(fillLight);

        // زمینة ساده (یک صفحه بازتابی)
        const gridHelper = new THREE.GridHelper(10, 20, 0x88aaff, 0x335588);
        gridHelper.position.y = -0.8;
        scene.add(gridHelper);
        
        const planeMat = new THREE.MeshStandardMaterial({ color: 0x1a1a2e, roughness: 0.7, metalness: 0.1, transparent: true, opacity: 0.5 });
        const groundPlane = new THREE.Mesh(new THREE.PlaneGeometry(8, 6), planeMat);
        groundPlane.rotation.x = -Math.PI / 2;
        groundPlane.position.y = -0.75;
        scene.add(groundPlane);

        // ========== بدنه اصلی کیف ==========
        const bodyWidth = 0.09;   // 90mm
        const bodyHeight = 0.012; // 12mm
        const bodyDepth = 0.06;   // 60mm
        
        // مواد: تیتانیوم برس خورده
        const metalMaterial = new THREE.MeshStandardMaterial({
            color: 0x8899aa,
            roughness: 0.25,
            metalness: 0.95,
            emissive: 0x000000,
            flatShading: false
        });
        
        const body = new THREE.Mesh(new THREE.BoxGeometry(bodyWidth, bodyHeight, bodyDepth), metalMaterial);
        body.castShadow = true;
        body.receiveShadow = false;
        scene.add(body);
        
        // لبه‌های الماس‌شکل (اضافه کردن جزئیات با حلقه‌های باریک)
        const edgeMaterial = new THREE.MeshStandardMaterial({ color: 0xccaa77, metalness: 0.98, roughness: 0.2 });
        const topEdge = new THREE.Mesh(new THREE.BoxGeometry(bodyWidth + 0.002, 0.001, bodyDepth + 0.002), edgeMaterial);
        topEdge.position.y = bodyHeight/2 + 0.0005;
        scene.add(topEdge);
        
        // ========== سنسور اثر انگشت (روی درب بالا) ==========
        const sensorGeometry = new THREE.CylinderGeometry(0.008, 0.008, 0.0015, 32);
        const sensorMat = new THREE.MeshStandardMaterial({ color: 0x333333, metalness: 0.2, roughness: 0.1, emissive: 0x111111 });
        const sensor = new THREE.Mesh(sensorGeometry, sensorMat);
        sensor.position.set(0, bodyHeight/2 + 0.001, 0.01);
        sensor.rotation.x = 0;
        scene.add(sensor);
        
        // حلقه طلایی دور سنسور
        const ringGeo = new THREE.TorusGeometry(0.009, 0.0008, 32, 100);
        const ringMat = new THREE.MeshStandardMaterial({ color: 0xffaa55, metalness: 0.9, roughness: 0.3 });
        const ring = new THREE.Mesh(ringGeo, ringMat);
        ring.position.set(0, bodyHeight/2 + 0.0012, 0.01);
        ring.rotation.x = Math.PI / 2;
        scene.add(ring);
        
        // ========== LED نشانگر (کوچک قرمز/آبی) ==========
        const ledMat = new THREE.MeshStandardMaterial({ color: 0xff3300, emissive: 0xff2200, emissiveIntensity: 0.8 });
        const led = new THREE.Mesh(new THREE.SphereGeometry(0.0015, 16, 16), ledMat);
        led.position.set(0.03, bodyHeight/2 + 0.001, 0.025);
        scene.add(led);
        
        // ========== کلیدهای لمسی (6 نقطه) ==========
        const touchMat = new THREE.MeshStandardMaterial({ color: 0xccaaff, metalness: 0.1, emissive: 0x222222 });
        const positions = [
            [-0.025, bodyHeight/2 + 0.0012, 0.022], [-0.005, bodyHeight/2 + 0.0012, 0.022],
            [0.015, bodyHeight/2 + 0.0012, 0.022], [-0.025, bodyHeight/2 + 0.0012, 0.012],
            [-0.005, bodyHeight/2 + 0.0012, 0.012], [0.015, bodyHeight/2 + 0.0012, 0.012]
        ];
        positions.forEach(pos => {
            const touchKey = new THREE.Mesh(new THREE.BoxGeometry(0.006, 0.0008, 0.006), touchMat);
            touchKey.position.set(pos[0], pos[1], pos[2]);
            scene.add(touchKey);
        });
        
        // ========== محفظه کارت (نمایش نیمه باز) ==========
        const cardSlotMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.5, metalness: 0.3 });
        const slot = new THREE.Mesh(new THREE.BoxGeometry(0.08, 0.004, 0.055), cardSlotMat);
        slot.position.set(0, -bodyHeight/2 - 0.002, 0);
        scene.add(slot);
        
        // یک کارت که کمی بیرون زده
        const cardMat = new THREE.MeshStandardMaterial({ color: 0xdd9977, metalness: 0.1, roughness: 0.6 });
        const card = new THREE.Mesh(new THREE.BoxGeometry(0.075, 0.0008, 0.052), cardMat);
        card.position.set(0.01, -bodyHeight/2 - 0.002, 0.015);
        card.rotation.z = 0.05;
        scene.add(card);
        
        // ========== اهرم کناری برای بیرون زدن کارت ==========
        const leverMat = new THREE.MeshStandardMaterial({ color: 0xaa8866, metalness: 0.7 });
        const lever = new THREE.Mesh(new THREE.BoxGeometry(0.008, 0.002, 0.012), leverMat);
        lever.position.set(bodyWidth/2 + 0.006, 0.002, -0.02);
        scene.add(lever);
        
        // ========== متن‌های CSS2D برای برچسب ==========
        function makeLabel(text, color, position) {
            const div = document.createElement('div');
            div.textContent = text;
            div.style.color = color;
            div.style.fontSize = '12px';
            div.style.fontWeight = 'bold';
            div.style.textShadow = '1px 1px 0px black';
            div.style.background = 'rgba(0,0,0,0.5)';
            div.style.padding = '2px 5px';
            div.style.borderRadius = '4px';
            div.style.borderLeft = `3px solid ${color}`;
            div.style.fontFamily = 'monospace';
            const label = new CSS2DObject(div);
            label.position.copy(position);
            scene.add(label);
        }
        
        makeLabel('🔒 اثر انگشت', '#88ff88', new THREE.Vector3(0, 0.012, 0.022));
        makeLabel('⌨️ کلیدهای لمسی', '#ffaa88', new THREE.Vector3(-0.01, 0.012, 0.032));
        makeLabel('📇 خروج کارت', '#88aaff', new THREE.Vector3(0.045, -0.01, 0.02));
        makeLabel('GPS & BLE', '#ff88ff', new THREE.Vector3(0.04, 0.008, -0.03));
        
        // ========== حلقه انیمیشن ==========
        let time = 0;
        function animate() {
            requestAnimationFrame(animate);
            time += 0.02;
            // چشمک زدن LED
            led.material.emissiveIntensity = 0.5 + Math.sin(time * 15) * 0.3;
            // چرخش آرام خودکار اگر کاربر دست نزند
            if (controls.autoRotate) {
                controls.update();
            }
            renderer.render(scene, camera);
            labelRenderer.render(scene, camera);
        }
        
        animate();
        
        // توقف خودچرخش هنگام تعامل کاربر
        controls.autoRotate = true;
        controls.addEventListener('start', () => { controls.autoRotate = false; });
        controls.addEventListener('end', () => { setTimeout(() => { if (!controls.autoRotate) controls.autoRotate = true; }, 3000); });
        
        // تنظیم پنجره
        window.addEventListener('resize', onWindowResize, false);
        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
            labelRenderer.setSize(window.innerWidth, window.innerHeight);
        }
    </script>
</body>
</html>